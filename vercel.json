{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/regenerate.py": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/output/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
